# =============================================
# EASY CAR LUXURY - VARIABLES DE ENTORNO
# Copiar este archivo a .env y modificar según entorno
# =============================================

# Aplicación
APP_ENV=development
APP_URL=http://localhost:8000
APP_NAME="Easy Car Luxury"

# Base de Datos
DB_HOST=localhost
DB_NAME=easycarluxury
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# JWT (cambiar por una clave segura!)
JWT_SECRET=tu-clave-secreta-muy-segura-cambiala-en-produccion

# DIAN Facturación Electrónica
DIAN_ENVIRONMENT=test
DIAN_NIT=900123456
DIAN_RESOLUTION_NUMBER=18760000001
DIAN_RESOLUTION_DATE=2025-01-01
DIAN_TECHNICAL_KEY=tu-technical-key
DIAN_CERTIFICATE_PATH=/certs/certificate.p12
DIAN_CERTIFICATE_PASSWORD=tu-password-certificado

# Pasarelas de Pago - Wompi (Recomendada)
WOMPI_PUBLIC_KEY=pub_test_xxxxx
WOMPI_PRIVATE_KEY=pri_test_xxxxx

# Pasarelas de Pago - PayU (Opcional)
PAYU_MERCHANT_ID=
PAYU_API_KEY=
PAYU_API_LOGIN=

# Email SMTP (SendGrid/Amazon SES/Gmail)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=tu-api-key-de-sendgrid
SMTP_FROM_EMAIL=noreply@easycarluxury.com
SMTP_FROM_NAME="Easy Car Luxury"

# WhatsApp Business API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_BUSINESS_ID=

# Auditoría y Seguridad
ENCRYPTION_KEY=tu-llave-de-encriptacion
AUDIT_LOG_RETENTION_DAYS=90

# Sistema
IVA_PERCENTAGE=19
BACKUP_ENABLED=true
BACKUP_DAILY_HOUR=3