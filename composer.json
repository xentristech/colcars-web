{
    "name": "easycarluxury/easycarluxury",
    "description": "Plataforma de venta de vehículos de lujo y embarcaciones",
    "type": "project",
    "require": {
        "php": ">=7.4.0",
        "firebase/php-jwt": "^7.0",
        "mpdf/mpdf": "^8.3",
        "phpmailer/phpmailer": "^7.0",
        "phpoffice/phpspreadsheet": "^5.7",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "monolog/monolog": "^3.5"
    },
    "autoload": {
        "psr-4": {
            "EasyCarLuxury\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "audit": {
            "ignore": ["PKSA-y2cr-5h3j-g3ys"]
        }
    },
    "scripts": {
        "post-install-cmd": [
            "echo '✅ Dependencias instaladas correctamente'"
        ],
        "migrate": "php scripts/migrate.php",
        "seed": "php scripts/seed.php"
    }
}
